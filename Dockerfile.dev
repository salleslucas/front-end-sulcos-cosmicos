# ─── Desenvolvimento com Hot Reload (Vite HMR) ────────────────────────────────
FROM node:22-alpine

WORKDIR /app

# Copia dependências e instala
COPY package*.json ./
RUN npm ci

# O código-fonte é montado via volume (não copiado aqui)
EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
